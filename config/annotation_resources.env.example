annotation_resources.env 
# -------------------- core reference --------------------
REF_FASTA="/home/student/rare_disease_project/refs/Homo_sapiens.GRCh38.dna.primary_assembly.fa"
JAVA_MEM="8g"

# -------------------- VEP --------------------
VEP_CACHE_DIR="/home/student/rare_disease_project/refs/vep_cache"
RUN_VEP=1

# -------------------- SnpEff --------------------
RUN_SNPEFF=1
SNPEFF_JAR="/home/student/bioinformatics_tools/snpEff/snpEff.jar"
SNPEFF_GENOME="GRCh38.86"

# -------------------- ClinVar --------------------
RUN_CLINVAR=1
CLINVAR_VCF_GZ="/home/student/rare_disease_project/databases/clinvar/clinvar.chr.vcf.gz"

# -------------------- gnomAD --------------------
RUN_GNOMAD=1
GNOMAD_VCF_GZ="/home/student/rare_disease_project/databases/gnomad/gnomad_subset.sorted.vcf.gz"

# -------------------- ClinGen --------------------
RUN_CLINGEN=1
CLINGEN_DOSAGE_BED_GZ="/home/student/rare_disease_project/databases/clingen/clingen_dosage.hg38.bed.gz"

# -------------------- SpliceAI --------------------
RUN_SPLICEAI=1

# -------------------- REVEL/AlphaMissense/CADD (via MyVariant.info subset) --------------------
RUN_DBNSFP_BED=1
DBNSFP_BED_GZ="/home/student/rare_disease_project/databases/myvariant/dbnsfp_scores.bed.gz"

# -------------------- ACMG/AMP classification (via wINTERVAR subset) --------------------
RUN_INTERVAR_BED=1
INTERVAR_BED_GZ="/home/student/rare_disease_project/databases/intervar/intervar_combined.bed.gz"
ENV_END

echo "Config created."
