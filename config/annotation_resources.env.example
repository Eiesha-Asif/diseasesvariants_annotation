###############################################################################
# annotation_resources.env.example
#
# Copy this file to annotation_resources.env and adjust paths only if you
# changed the default directory layout. All paths below match what
# scripts/setup_tools.sh, scripts/setup_databases.sh, and the fetch_*.sh
# scripts create automatically -- no manual downloading is required.
#
#   cp config/annotation_resources.env.example config/annotation_resources.env
###############################################################################

# -------------------- core reference --------------------
REF_FASTA="${PWD}/refs/Homo_sapiens.GRCh38.dna.primary_assembly.fa"
JAVA_MEM="4g"

# -------------------- Step 2: Ensembl VEP --------------------
RUN_VEP=1
VEP_CACHE_DIR="${PWD}/refs/vep_cache"

# -------------------- Step 3: SnpEff --------------------
RUN_SNPEFF=1
SNPEFF_JAR="${PWD}/tools/snpEff/snpEff.jar"
SNPEFF_GENOME="GRCh38.86"

# -------------------- Step 4: ClinVar --------------------
RUN_CLINVAR=1
CLINVAR_VCF_GZ="${PWD}/databases/clinvar/clinvar.chr.vcf.gz"
CLINVAR_INFO_FIELDS="INFO/CLNSIG,INFO/CLNREVSTAT,INFO/CLNDN,INFO/CLNDISDB,INFO/CLNHGVS,INFO/CLNVC,INFO/CLNVCSO,INFO/GENEINFO"

# -------------------- Step 5: gnomAD --------------------
# Generated by: bash scripts/fetch_gnomad_subset.sh <input.vcf.gz> databases/gnomad/subset
RUN_GNOMAD=1
GNOMAD_BED_GZ="${PWD}/databases/gnomad/subset.bed.gz"

# -------------------- Step 6: ClinGen dosage sensitivity --------------------
RUN_CLINGEN=1
CLINGEN_DOSAGE_BED_GZ="${PWD}/databases/clingen/clingen_dosage.hg38.bed.gz"

# -------------------- Step 7: SpliceAI --------------------
# Requires: conda activate spliceai_env   (before running the main pipeline script)
RUN_SPLICEAI=1

# -------------------- Step 8: REVEL / AlphaMissense / CADD (dbNSFP) --------------------
# Generated by: bash scripts/fetch_dbnsfp_subset.sh <input.vcf.gz> databases/dbnsfp/subset
RUN_DBNSFP=1
DBNSFP_BED_GZ="${PWD}/databases/dbnsfp/subset.bed.gz"

# -------------------- Step 9: ACMG/AMP classification (wINTERVAR) --------------------
# Generated by: bash scripts/prepare_intervar_queries.sh <input.vcf.gz>   (manual web step)
#               bash scripts/fetch_intervar_subset.sh <csv_folder> databases/intervar/subset
RUN_INTERVAR=1
INTERVAR_BED_GZ="${PWD}/databases/intervar/subset.bed.gz"
